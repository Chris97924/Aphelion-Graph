  "sampling_algorithm": "question_ids sorted lexicographically per pool, then random.Random(20260717).sample; KU pool taken in full (no sampling)",
  "metrics": {
    "M1": {
      "gate": "C-B >= +3pp on knowledge-update",
      "N": 78,
      "reporting": "directional, bootstrapped CI, C-A secondary"
